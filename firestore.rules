rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reads the caller's role from their Firestore user document.
    // Cached by Firestore per request — safe to call multiple times.
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && callerRole() == 'admin';
    }

    function isDriver() {
      return isSignedIn() && callerRole() == 'driver';
    }

    function isPassenger() {
      return isSignedIn() && callerRole() == 'passenger';
    }

    // ── users ────────────────────────────────────────────────────────────────
    // • Any authenticated user can read their own document.
    // • Users may update only a safe subset of their own fields.
    // • Admins can read and update any user document (e.g. set verificationStatus).
    // • Only the backend / admin SDK creates user documents (no client create/delete).

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      // Self: update only personal / vehicle fields — not role or verificationStatus.
      allow update: if isSelf(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'verificationStatus', 'idFrontUrl', 'idBackUrl', 'createdAt'])
        || isAdmin();

      // Drivers may update their own idFrontUrl / idBackUrl / verificationStatus
      // only when setting status to 'pending' (i.e. submitting for the first time).
      allow update: if isSelf(uid)
        && isDriver()
        && request.resource.data.verificationStatus == 'pending'
        && resource.data.verificationStatus in ['unsubmitted', 'pending'];
    }

    // ── rides ────────────────────────────────────────────────────────────────
    // • Anyone signed in can list / read active rides.
    // • Only the owning driver can create or update their own ride.
    // • Passengers may increment bookedSeats only (handled via transaction).
    // • Admins have full access.

    match /rides/{rideId} {
      allow read: if isSignedIn();

      allow create: if isDriver()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.bookedSeats == 0
        && request.resource.data.status == 'active';

      // Driver may update their own ride (e.g. cancel it).
      allow update: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid)
        // Passengers may only increment bookedSeats by a positive amount
        // when the ride is still active and not yet full.
        || (isPassenger()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedSeats'])
            && request.resource.data.bookedSeats > resource.data.bookedSeats
            && resource.data.status == 'active'
            && resource.data.bookedSeats < resource.data.totalSeats);

      allow delete: if isAdmin();
    }

    // ── bookings ─────────────────────────────────────────────────────────────
    // • A passenger can read and create their own bookings.
    // • A driver can read bookings for their rides.
    // • A passenger may update only the status field (to 'cancelled').
    // • Admins have full access.

    match /bookings/{bookingId} {
      allow read: if isAdmin()
        || (isSignedIn() && (
            resource.data.passengerId == request.auth.uid
            || resource.data.driverId == request.auth.uid
           ));

      allow create: if isPassenger()
        && request.resource.data.passengerId == request.auth.uid
        && request.resource.data.status == 'confirmed';

      // Passenger may cancel only their own confirmed booking.
      allow update: if isAdmin()
        || (isPassenger()
            && resource.data.passengerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && request.resource.data.status == 'cancelled'
            && resource.data.status == 'confirmed');

      allow delete: if isAdmin();
    }

    // ── chats ────────────────────────────────────────────────────────────────
    // • Only participants of a chat may read or write it.
    // • Admins may read any chat (moderation).

    match /chats/{chatId} {
      allow read, write: if isAdmin()
        || (isSignedIn()
            && request.auth.uid in resource.data.participants);

      // Allow creating a new chat document when the caller is one of the participants.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAdmin()
          || (isSignedIn()
              && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;

        // Messages are immutable once written.
        allow update, delete: if isAdmin();
      }
    }
  }
}
